{
  "annotations": {
    "list": []
  },
  "editable": true,
  "graphTooltip": 0,
  "panels": [
    {
      "type": "timeseries",
      "title": "Namespace Pod Count",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "expr": "count(kube_pod_info{namespace=\"finch\"})",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Namespace CPU Usage",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "targets": [
        {
          "expr": "sum(rate(container_cpu_usage_seconds_total{namespace=\"finch\"}[5m]))",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Namespace Memory Usage",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "targets": [
        {
          "expr": "sum(container_memory_usage_bytes{namespace=\"finch\"})",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Running Pods",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "targets": [
        {
          "expr": "sum(kube_pod_status_phase{namespace=\"finch\",phase=\"Running\"})",
          "refId": "A"
        }
      ]
    }
  ],
