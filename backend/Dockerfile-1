# Backend Dockerfile
FROM node:18-alpine

WORKDIR /app

# Copy package files
COPY package*.json ./

# Install dependencies with fallback options
RUN npm install --omit=dev --registry=https://registry.npmjs.org/ || \
    npm install --omit=dev --registry=https://registry.npmmirror.com/

# Copy source code
COPY . .

# Expose backend port
EXPOSE 3000

# Start the server
CMD ["npm", "start"]
